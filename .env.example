# ─── Constructor Express — Variables de Entorno ───────────────────────────────
# Copia este archivo a .env y rellena los valores

# Seguridad (OBLIGATORIO en producción)
SECRET_KEY=cambia-esto-por-una-clave-segura-de-50-chars-minimo
DEBUG=False
ALLOWED_HOSTS=tudominio.cl,www.tudominio.cl

# Base de datos PostgreSQL (producción)
DATABASE_URL=postgres://usuario:contraseña@localhost:5432/constructor_express_db

# Email (producción — usar SendGrid, Mailgun, SES, etc.)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=tu-api-key-sendgrid
# DEFAULT_FROM_EMAIL=Constructor Express <noreply@tudominio.cl>

# En desarrollo (SQLite, sin configuración extra)
# SECRET_KEY=cualquier-clave-para-desarrollo
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1
